---
import Comment from "@components/comment/index.astro";
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";

export const prerender = true;

const title = "留言板";
const subtitle = "在这里留下你的想法、建议或者随便说点什么";
---

<MainGridLayout title={title} description={subtitle}>
	<div
		id="message-section"
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			<div class="mt-4 space-y-3 text-black/75 dark:text-white/75 leading-relaxed">
				<p>
					如果你有想说的话、想提的建议，或者只是想打个招呼，都可以在下面直接留言。
				</p>
				<p>
					这里使用的是站点现有评论系统，留言内容会展示在本页下方。
				</p>
			</div>
		</div>
	</div>

	<div class="mt-4">
		<Comment path="/message/" />
	</div>
</MainGridLayout>
