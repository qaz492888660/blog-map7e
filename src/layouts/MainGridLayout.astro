---
import FloatingControls from "@components/control/FloatingControls.astro";
import { SidebarTOC } from "@components/features/toc";
import Banner from "@components/layout/Banner.astro";
import RightSideBar from "@components/layout/RightSideBar.astro";
import FullscreenWallpaper from "@components/misc/FullscreenWallpaper.astro";
import IconifyLoader from "@components/misc/IconifyLoader.astro";
import Footer from "@components/organisms/footer/Footer.astro";
import Navbar from "@components/organisms/navigation/Navbar.astro";
import SideBar from "@components/widgets/sidebar/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";

import { fullscreenWallpaperConfig, siteConfig } from "../config";
import { BANNER_HEIGHT } from "../constants/constants";
import {
	calculateGridLayout,
	getBannerImages,
	getMainPanelTop,
	getTransparencyClass,
	shouldEnableTransparency,
} from "../utils/grid-layout-utils";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";
import GridScripts from "./partials/GridScripts.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	headings?: MarkdownHeading[];
}

const bannerImages = await getBannerImages(siteConfig);

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	headings = [],
} = Astro.props;

const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";

const finalMainPanelTop = getMainPanelTop(
	siteConfig.wallpaperMode.defaultMode,
	BANNER_HEIGHT,
);

const {
	gridCols,
	sidebarClass,
	rightSidebarClass,
	mainContentClass,
	sidebarPresence,
	mobileShowSidebar,
	tabletShowSidebar,
	desktopShowSidebar,
} = calculateGridLayout({
	siteConfig,
	widgetManager,
});

const { hasRightSidebarComponents, hasMobileDrawerComponents } =
	sidebarPresence;

const shouldEnable = shouldEnableTransparency(
	siteConfig.wallpaperMode.defaultMode,
);
const transparentClass = getTransparencyClass(shouldEnable);
const defaultPostListLayout = siteConfig.postListLayout?.defaultMode || "list";

const homeBubbles = [
	{
		left: "4%",
		size: "0.65rem",
		duration: "17s",
		delay: "-3s",
		drift: "14px",
		bottom: "10%",
	},
	{
		left: "9%",
		size: "1.18rem",
		duration: "24s",
		delay: "-11s",
		drift: "-16px",
		bottom: "6%",
	},
	{
		left: "15%",
		size: "0.82rem",
		duration: "20s",
		delay: "-5s",
		drift: "12px",
		bottom: "18%",
	},
	{
		left: "22%",
		size: "1.45rem",
		duration: "29s",
		delay: "-18s",
		drift: "20px",
		bottom: "9%",
	},
	{
		left: "29%",
		size: "0.74rem",
		duration: "19s",
		delay: "-8s",
		drift: "-10px",
		bottom: "15%",
	},
	{
		left: "36%",
		size: "1.05rem",
		duration: "23s",
		delay: "-14s",
		drift: "18px",
		bottom: "7%",
	},
	{
		left: "43%",
		size: "0.58rem",
		duration: "16s",
		delay: "-2s",
		drift: "-12px",
		bottom: "13%",
	},
	{
		left: "49%",
		size: "1.62rem",
		duration: "31s",
		delay: "-21s",
		drift: "22px",
		bottom: "5%",
	},
	{
		left: "55%",
		size: "0.88rem",
		duration: "22s",
		delay: "-9s",
		drift: "-14px",
		bottom: "16%",
	},
	{
		left: "61%",
		size: "1.12rem",
		duration: "25s",
		delay: "-12s",
		drift: "16px",
		bottom: "8%",
	},
	{
		left: "67%",
		size: "0.7rem",
		duration: "18s",
		delay: "-6s",
		drift: "10px",
		bottom: "20%",
	},
	{
		left: "73%",
		size: "1.38rem",
		duration: "28s",
		delay: "-16s",
		drift: "-18px",
		bottom: "6%",
	},
	{
		left: "79%",
		size: "0.78rem",
		duration: "21s",
		delay: "-7s",
		drift: "12px",
		bottom: "14%",
	},
	{
		left: "85%",
		size: "1rem",
		duration: "24s",
		delay: "-13s",
		drift: "-12px",
		bottom: "11%",
	},
	{
		left: "91%",
		size: "0.62rem",
		duration: "18s",
		delay: "-4s",
		drift: "9px",
		bottom: "17%",
	},
	{
		left: "95%",
		size: "1.28rem",
		duration: "27s",
		delay: "-19s",
		drift: "-14px",
		bottom: "7%",
	},
];
---

<Layout
	title={title}
	banner={banner}
	description={description}
	lang={lang}
	setOGTypeArticle={setOGTypeArticle}
	postSlug={postSlug}
>
	<GridScripts
		navbarTransparentMode={siteConfig.banner?.navbar?.transparentMode ||
			"semi"}
		defaultWallpaperMode={siteConfig.wallpaperMode.defaultMode}
		defaultPostListLayout={siteConfig.postListLayout?.defaultMode || "list"}
		BANNER_HEIGHT={BANNER_HEIGHT}
		pageScaling={siteConfig.pageScaling}
	/>

	<FullscreenWallpaper config={fullscreenWallpaperConfig} />
	<IconifyLoader />

	<slot slot="head" name="head" />

	<div
		id="top-row"
		class="z-50 pointer-events-none relative transition-all duration-700 max-w-(--page-width) px-0 md:px-4 mx-auto"
		class:list={[""]}
	>
		<div
			id="navbar-wrapper"
			class="pointer-events-auto sticky top-0 transition-all"
		>
			<Navbar />
		</div>
	</div>

	<Banner
		bannerImages={bannerImages}
		mobileNonHomeBannerClass=""
		showTextOverlay={isHomePage &&
			(siteConfig.banner.homeText?.enable ?? false)}
	/>

	<div
		id="page-main-panel"
		class={`absolute w-full z-30 pointer-events-none ${siteConfig.wallpaperMode.defaultMode === "none" ? "no-banner-layout" : ""} ${transparentClass}`}
		style={`top: ${finalMainPanelTop}`}
	>
		<div class="relative max-w-(--page-width) mx-auto pointer-events-auto">
			{
				hasBannerCredit && (
					<a
						href={siteConfig.banner.credit.url}
						id="banner-credit"
						target="_blank"
						rel="noopener"
						aria-label="Visit image source"
						class:list={[
							"group onload-animation transition-all absolute z-20 flex justify-center items-center rounded-full " +
								"px-3 right-4 -top-13 bg-black/60 hover:bg-black/70 h-9",
							{
								"hover:pr-9 active:bg-black/80":
									hasBannerLink,
							},
						]}
					>
						<Icon
							class="text-white/75 text-[1.25rem] mr-1"
							name="material-symbols:copyright-outline-rounded"
						/>
						<div class="text-white/75 text-xs">
							{siteConfig.banner.credit.text}
						</div>
						<Icon
							class:list={[
								"transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
								{
									"group-hover:opacity-100":
										hasBannerLink,
								},
							]}
							name="fa7-solid:arrow-up-right-from-square"
						/>
					</a>
				)
			}

			<section
				class:list={[
					"underwater-section",
					{ "is-home-underwater": isHomePage },
				]}
			>
				{
					isHomePage && (
						<>
							<div class="underwater-surface" aria-hidden="true"></div>
							<div class="underwater-light" aria-hidden="true"></div>
							<div class="bubble-layer" aria-hidden="true">
								{
									homeBubbles.map((bubble) => (
										<span
											class="bubble"
											style={`--bubble-left:${bubble.left};--bubble-size:${bubble.size};--bubble-duration:${bubble.duration};--bubble-delay:${bubble.delay};--bubble-drift:${bubble.drift};--bubble-bottom:${bubble.bottom};`}
										></span>
									))
								}
							</div>
						</>
					)
				}

				<div
					id="main-grid"
					class={`relative z-10 transition duration-700 w-full left-0 right-0 grid ${gridCols} grid-rows-none md:grid-rows-[auto] mx-auto gap-4 px-2 md:px-4 ${!mobileShowSidebar || !hasMobileDrawerComponents ? "mobile-no-sidebar" : ""} ${hasRightSidebarComponents ? "mobile-both-sidebar" : ""}`}
					data-layout-mode={defaultPostListLayout}
				>
					<div class="contents">
						{
							(mobileShowSidebar ||
								tabletShowSidebar ||
								desktopShowSidebar) && (
								<SideBar
									class={`${sidebarClass} ${transparentClass}`}
									headings={headings}
								/>
							)
						}

						{
							hasRightSidebarComponents && (
								<div
									class={`right-sidebar-container ${rightSidebarClass} ${transparentClass}`}
								>
									<RightSideBar headings={headings} />
								</div>
							)
						}
					</div>

					<main
						id="swup-container"
						class={`${mainContentClass} transition-main`}
					>
						<div
							id="content-wrapper"
							class="onload-animation transition-leaving"
						>
							<slot />
							<div
								class="footer col-span-full onload-animation hidden lg:block"
							>
								<Footer />
							</div>
						</div>
					</main>

					<div
						class="footer col-span-full onload-animation block lg:hidden"
					>
						<Footer />
					</div>
				</div>
			</section>

			<FloatingControls headings={headings} />
		</div>
	</div>

	<style>
		.underwater-section {
			position: relative;
		}

		.underwater-section.is-home-underwater {
			position: relative;
			background:
				url("/images/underwater-background.png") center 28% / cover
					no-repeat !important;
			background-color: transparent !important;
			overflow: hidden;
			isolation: isolate;
			z-index: 0;
		}

		.underwater-section.is-home-underwater::before {
			content: "";
			position: absolute;
			top: 0;
			bottom: 0;
			left: 50%;
			width: 100vw;
			transform: translateX(-50%);
			z-index: 0;
			pointer-events: none;
			background:
				url("/images/underwater-background.png") center 28% / cover
					no-repeat !important;
		}

		.underwater-section.is-home-underwater::after {
			content: none;
		}

		.underwater-surface {
			position: absolute;
			top: -6rem;
			right: -6%;
			left: -6%;
			height: clamp(12rem, 22vw, 17rem);
			z-index: 1;
			pointer-events: none;
			background:
				radial-gradient(
					118% 92% at 50% -14%,
					rgba(255, 247, 232, 0.34) 0%,
					rgba(226, 247, 252, 0.16) 42%,
					rgba(148, 213, 232, 0.08) 62%,
					rgba(96, 163, 208, 0) 82%
				),
				radial-gradient(
					72% 66% at 50% 10%,
					rgba(255, 255, 255, 0.08) 0%,
					rgba(255, 255, 255, 0) 76%
				);
			filter: blur(20px);
			opacity: 0.62;
			mix-blend-mode: screen;
		}

		.underwater-surface::before {
			content: "";
			position: absolute;
			inset: 0;
			background:
				radial-gradient(
					24% 86% at 18% 42%,
					rgba(255, 255, 255, 0.12) 0%,
					rgba(255, 255, 255, 0) 70%
				),
				radial-gradient(
					28% 82% at 78% 36%,
					rgba(216, 247, 255, 0.12) 0%,
					rgba(216, 247, 255, 0) 72%
				);
			filter: blur(26px);
			opacity: 0.72;
		}

		.underwater-surface::after {
			content: none;
		}

		.underwater-light {
			position: absolute;
			top: 0;
			right: -4%;
			left: -4%;
			height: min(28rem, 44vw);
			z-index: 2;
			pointer-events: none;
			background:
				radial-gradient(
					20rem 12rem at 18% 8%,
					rgba(244, 253, 255, 0.14) 0%,
					rgba(244, 253, 255, 0) 72%
				),
				radial-gradient(
					20rem 12rem at 80% 12%,
					rgba(191, 241, 255, 0.12) 0%,
					rgba(191, 241, 255, 0) 74%
				),
				radial-gradient(
					34rem 18rem at 50% 10%,
					rgba(255, 255, 255, 0.07) 0%,
					rgba(255, 255, 255, 0) 72%
				);
			filter: blur(22px);
			mix-blend-mode: screen;
			opacity: 0.42;
		}

		.bubble-layer {
			position: absolute;
			inset: clamp(1rem, 3vw, 2rem) 0 0;
			z-index: 3;
			pointer-events: none;
			overflow: hidden;
		}

		.bubble {
			position: absolute;
			left: var(--bubble-left);
			bottom: var(--bubble-bottom);
			width: calc(var(--bubble-size) * 1.5);
			height: calc(var(--bubble-size) * 1.5);
			border-radius: 999px;
			background: radial-gradient(
				circle at 32% 28%,
				rgba(255, 255, 255, 0.82) 0%,
				rgba(255, 255, 255, 0.42) 24%,
				rgba(255, 255, 255, 0.18) 54%,
				rgba(255, 255, 255, 0) 78%
			);
			box-shadow:
				inset 0 0 0 1px rgba(255, 255, 255, 0.34),
				0 0 18px rgba(177, 235, 255, 0.22);
			filter: blur(0.1px);
			mix-blend-mode: screen;
			opacity: 0;
			will-change: transform, opacity;
			animation:
				underwater-bubble-rise var(--bubble-duration) linear infinite,
				underwater-bubble-sway calc(var(--bubble-duration) * 0.46)
					ease-in-out infinite;
			animation-delay: var(--bubble-delay);
		}

		.bubble:nth-child(4n) {
			box-shadow:
				inset 0 0 0 1px rgba(255, 255, 255, 0.4),
				0 0 24px rgba(202, 243, 255, 0.26);
		}

		.bubble:nth-child(5n) {
			background: radial-gradient(
				circle at 32% 28%,
				rgba(255, 255, 255, 0.88) 0%,
				rgba(255, 255, 255, 0.44) 22%,
				rgba(255, 255, 255, 0.16) 56%,
				rgba(255, 255, 255, 0) 80%
			);
		}

		@keyframes underwater-bubble-rise {
			0% {
				transform: translate3d(0, 3.5rem, 0) scale(0.7);
				opacity: 0;
			}

			12% {
				opacity: 0.28;
			}

			24% {
				opacity: 0.46;
			}

			78% {
				opacity: 0.28;
			}

			100% {
				transform: translate3d(var(--bubble-drift), -40rem, 0)
					scale(1.24);
				opacity: 0;
			}
		}

		@keyframes underwater-bubble-sway {
			0%,
			100% {
				margin-left: 0;
			}

			50% {
				margin-left: calc(var(--bubble-drift) * -0.65);
			}
		}

		.right-sidebar-container {
			align-self: start;
			display: contents;
		}

		.right-sidebar-container #right-sidebar {
			height: fit-content;
		}

		@media (max-width: 767px) {
			.underwater-surface {
				top: -4.5rem;
				height: clamp(9rem, 24vw, 12rem);
			}

			.underwater-light {
				height: min(20rem, 56vw);
				opacity: 0.38;
			}

			.bubble:nth-child(3n) {
				display: none;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.bubble {
				animation: none;
				opacity: 0.12;
			}
		}
	</style>

	{
		siteConfig.toc.enable && siteConfig.toc.desktopSidebar && (
			<div class="absolute w-full z-0 hidden 2xl:block">
				<div class="relative max-w-(--page-width) mx-auto">
					<div
						id="toc-wrapper"
						class:list={[
							"hidden lg:block transition absolute top-0 w-(--toc-width) items-center",
							"-right-(--toc-width)",
							{
								"toc-hide":
									siteConfig.wallpaperMode.defaultMode ===
									"banner",
							},
						]}
					>
						<div
							id="toc-inner-wrapper"
							class="fixed top-14 w-(--toc-width) max-h-[calc(100vh-10rem)] overflow-x-hidden overflow-y-auto"
						>
							<div
								id="toc-container"
								class="w-full transition-swup-fade"
							>
								<SidebarTOC headings={headings} />
							</div>
						</div>
					</div>
				</div>
			</div>
		)
	}

	{
		(!siteConfig.toc.enable || !siteConfig.toc.desktopSidebar) && (
			<div id="toc-container" class="hidden" />
		)
	}
</Layout>

<!--
  Banner and grid layout styles are imported by src/styles/main.css
-->
