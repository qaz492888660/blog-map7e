---
import FloatingControls from "@components/control/FloatingControls.astro";
import { SidebarTOC } from "@components/features/toc";
import Banner from "@components/layout/Banner.astro";
import RightSideBar from "@components/layout/RightSideBar.astro";
import FullscreenWallpaper from "@components/misc/FullscreenWallpaper.astro";
import IconifyLoader from "@components/misc/IconifyLoader.astro";
import Footer from "@components/organisms/footer/Footer.astro";
import Navbar from "@components/organisms/navigation/Navbar.astro";
import SideBar from "@components/widgets/sidebar/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";

import { fullscreenWallpaperConfig, siteConfig } from "../config";
import { BANNER_HEIGHT } from "../constants/constants";
import {
	calculateGridLayout,
	getBannerImages,
	getMainPanelTop,
	getTransparencyClass,
	shouldEnableTransparency,
} from "../utils/grid-layout-utils";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";
import GridScripts from "./partials/GridScripts.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	headings?: MarkdownHeading[];
}

const bannerImages = await getBannerImages(siteConfig);

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	headings = [],
} = Astro.props;

const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";

const finalMainPanelTop = getMainPanelTop(
	siteConfig.wallpaperMode.defaultMode,
	BANNER_HEIGHT,
);

const {
	gridCols,
	sidebarClass,
	rightSidebarClass,
	mainContentClass,
	sidebarPresence,
	mobileShowSidebar,
	tabletShowSidebar,
	desktopShowSidebar,
} = calculateGridLayout({
	siteConfig,
	widgetManager,
});

const { hasRightSidebarComponents, hasMobileDrawerComponents } =
	sidebarPresence;

const shouldEnable = shouldEnableTransparency(
	siteConfig.wallpaperMode.defaultMode,
);
const transparentClass = getTransparencyClass(shouldEnable);
const defaultPostListLayout = siteConfig.postListLayout?.defaultMode || "list";

const mainGridClass = `relative z-10 transition duration-700 w-full left-0 right-0 grid ${gridCols} grid-rows-none md:grid-rows-[auto] mx-auto gap-4 px-2 md:px-4 ${!mobileShowSidebar || !hasMobileDrawerComponents ? "mobile-no-sidebar" : ""} ${hasRightSidebarComponents ? "mobile-both-sidebar" : ""}`;
---

<Layout
	title={title}
	banner={banner}
	description={description}
	lang={lang}
	setOGTypeArticle={setOGTypeArticle}
	postSlug={postSlug}
>
	<GridScripts
		navbarTransparentMode={siteConfig.banner?.navbar?.transparentMode ||
			"semi"}
		defaultWallpaperMode={siteConfig.wallpaperMode.defaultMode}
		defaultPostListLayout={siteConfig.postListLayout?.defaultMode || "list"}
		BANNER_HEIGHT={BANNER_HEIGHT}
		pageScaling={siteConfig.pageScaling}
	/>

	<FullscreenWallpaper config={fullscreenWallpaperConfig} />
	<IconifyLoader />

	<slot slot="head" name="head" />

	{
		isHomePage ? (
			<section id="home-first-screen" class="home-hero-screen">
				<div
					id="top-row"
					class="z-50 pointer-events-none relative transition-all duration-700 max-w-(--page-width) px-0 md:px-4 mx-auto"
					class:list={[""]}
				>
					<div
						id="navbar-wrapper"
						class="pointer-events-auto sticky top-0 transition-all"
					>
						<Navbar />
					</div>
				</div>

				<Banner
					bannerImages={bannerImages}
					mobileNonHomeBannerClass=""
					showTextOverlay={siteConfig.banner.homeText?.enable ?? false}
				/>
			</section>
		) : (
			<>
				<div
					id="top-row"
					class="z-50 pointer-events-none relative transition-all duration-700 max-w-(--page-width) px-0 md:px-4 mx-auto"
					class:list={[""]}
				>
					<div
						id="navbar-wrapper"
						class="pointer-events-auto sticky top-0 transition-all"
					>
						<Navbar />
					</div>
				</div>

				<Banner
					bannerImages={bannerImages}
					mobileNonHomeBannerClass=""
					showTextOverlay={false}
				/>
			</>
		)
	}

	<div
		id="page-main-panel"
		class={`absolute w-full z-30 pointer-events-none ${siteConfig.wallpaperMode.defaultMode === "none" ? "no-banner-layout" : ""} ${transparentClass}`}
		style={`top: ${finalMainPanelTop}`}
	>
		<div
			class:list={[
				"relative pointer-events-auto",
				isHomePage ? "w-full" : "max-w-(--page-width) mx-auto",
			]}
		>
			{
				hasBannerCredit && (
					<a
						href={siteConfig.banner.credit.url}
						id="banner-credit"
						target="_blank"
						rel="noopener"
						aria-label="Visit image source"
						class:list={[
							"group onload-animation transition-all absolute z-20 flex justify-center items-center rounded-full " +
								"px-3 right-4 -top-13 bg-black/60 hover:bg-black/70 h-9",
							{
								"hover:pr-9 active:bg-black/80":
									hasBannerLink,
							},
						]}
					>
						<Icon
							class="text-white/75 text-[1.25rem] mr-1"
							name="material-symbols:copyright-outline-rounded"
						/>
						<div class="text-white/75 text-xs">
							{siteConfig.banner.credit.text}
						</div>
						<Icon
							class:list={[
								"transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
								{
									"group-hover:opacity-100":
										hasBannerLink,
								},
							]}
							name="fa7-solid:arrow-up-right-from-square"
						/>
					</a>
				)
			}

			<section
				id="page-second-screen"
				class:list={[
					"relative",
					{ "underwater-section is-home-underwater": isHomePage },
				]}
				data-home-second-screen={isHomePage ? "true" : undefined}
			>
				{
					isHomePage && (
						<video
							class="underwater-video"
							autoplay
							loop
							muted
							playsinline
							preload="auto"
							aria-hidden="true"
						>
							<source src="/videos/underwater.mp4" type="video/mp4" />
						</video>
					)
				}

				<div
					class:list={[
						"relative max-w-(--page-width) mx-auto pointer-events-auto",
						{ "underwater-content": isHomePage },
					]}
				>
					<div
						id="main-grid"
						class={mainGridClass}
						data-layout-mode={defaultPostListLayout}
					>
						<div class="contents">
							{
								(mobileShowSidebar ||
									tabletShowSidebar ||
									desktopShowSidebar) && (
									<SideBar
										class={`${sidebarClass} ${transparentClass}`}
										headings={headings}
									/>
								)
							}

							{
								hasRightSidebarComponents && (
									<div
										class={`right-sidebar-container ${rightSidebarClass} ${transparentClass}`}
									>
										<RightSideBar headings={headings} />
									</div>
								)
							}
						</div>

						<main
							id="swup-container"
							class={`${mainContentClass} transition-main`}
						>
							<div
								id="content-wrapper"
								class="onload-animation transition-leaving"
							>
								<slot />
								<div
									class="footer col-span-full onload-animation hidden lg:block"
								>
									<Footer />
								</div>
							</div>
						</main>

						<div
							class="footer col-span-full onload-animation block lg:hidden"
						>
							<Footer />
						</div>
					</div>
				</div>
			</section>

			<FloatingControls headings={headings} />
		</div>
	</div>

	<style>
		.home-hero-screen {
			position: relative;
			width: 100%;
			min-height: 100vh;
			overflow: hidden;
		}

		.underwater-section.is-home-underwater {
			position: relative;
			min-height: 100vh;
			width: 100%;
			overflow: hidden;
			isolation: isolate;
		}

		.underwater-video {
			position: absolute;
			top: 0;
			bottom: 0;
			left: 50%;
			transform: translateX(-50%);
			width: 100vw;
			min-width: 100vw;
			height: 100%;
			object-fit: cover;
			z-index: 0;
			pointer-events: none;
			filter: brightness(0.85) saturate(1.05);
		}

		.underwater-content {
			position: relative;
			z-index: 2;
			min-height: 100vh;
		}

		.right-sidebar-container {
			align-self: start;
			display: contents;
		}

		.right-sidebar-container #right-sidebar {
			height: fit-content;
		}
	</style>

	<style is:global>
		html:has(body.lg\:is-home),
		body.lg\:is-home {
			scroll-snap-type: y mandatory;
			scroll-behavior: smooth;
		}

		body.lg\:is-home #home-first-screen,
		body.lg\:is-home
			#page-second-screen[data-home-second-screen="true"] {
			min-height: 100vh;
			scroll-snap-align: start;
			scroll-snap-stop: always;
		}
	</style>

	{
		siteConfig.toc.enable && siteConfig.toc.desktopSidebar && (
			<div class="absolute w-full z-0 hidden 2xl:block">
				<div class="relative max-w-(--page-width) mx-auto">
					<div
						id="toc-wrapper"
						class:list={[
							"hidden lg:block transition absolute top-0 w-(--toc-width) items-center",
							"-right-(--toc-width)",
							{
								"toc-hide":
									siteConfig.wallpaperMode.defaultMode ===
									"banner",
							},
						]}
					>
						<div
							id="toc-inner-wrapper"
							class="fixed top-14 w-(--toc-width) max-h-[calc(100vh-10rem)] overflow-x-hidden overflow-y-auto"
						>
							<div
								id="toc-container"
								class="w-full transition-swup-fade"
							>
								<SidebarTOC headings={headings} />
							</div>
						</div>
					</div>
				</div>
			</div>
		)
	}

	{
		(!siteConfig.toc.enable || !siteConfig.toc.desktopSidebar) && (
			<div id="toc-container" class="hidden" />
		)
	}
</Layout>

<!--
  Banner and grid layout styles are imported by src/styles/main.css
-->
