---
import { musicPlayerConfig } from "../../config";
import MusicFabButton from "./MusicFabButton.svelte";
import ScrollToggleButton from "./ScrollToggleButton.astro";
---

<div class="floating-controls-container">
	<div class="floating-control-item" data-control-key="scroll-toggle">
		<ScrollToggleButton />
	</div>
	{
		musicPlayerConfig.enable &&
			musicPlayerConfig.showFloatingPlayer &&
			(musicPlayerConfig.floatingEntryMode ?? "default") === "fab" && (
				<div class="floating-control-item" data-control-key="music">
					<MusicFabButton client:idle />
				</div>
			)
	}
</div>

<style>
	:global(:root) {
		--fab-group-right: 1.5rem;
		--fab-group-bottom: 10rem;
		--fab-group-base-bottom: 10rem;
		--fab-group-gap: 0.5rem;
		--fab-button-size: 3rem;
		--fab-visible-count: 1;
	}

	.floating-controls-container {
		position: fixed;
		z-index: 50;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		pointer-events: none;

		right: var(--fab-group-right);
		bottom: var(--fab-group-bottom);
		transition: bottom 0.28s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.floating-control-item {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		pointer-events: auto;
		max-height: var(--fab-button-size);
		opacity: 1;
		transform: translateY(0) scale(1);
		transform-origin: bottom right;
		transition:
			max-height 0.28s cubic-bezier(0.4, 0, 0.2, 1),
			opacity 0.2s ease,
			transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
			margin-top 0.28s cubic-bezier(0.4, 0, 0.2, 1);
		overflow: visible;
	}

	.floating-control-item.is-stacked {
		margin-top: var(--fab-group-gap);
	}

	.floating-control-item.is-collapsed {
		max-height: 0;
		opacity: 0;
		transform: translateY(0.25rem) scale(0.92);
		margin-top: 0 !important;
		pointer-events: none;
	}

	:global(html.fab-visibility-locked #scroll-toggle-btn.fab-lock-visible) {
		min-width: var(--fab-button-size) !important;
		min-height: var(--fab-button-size) !important;
		transform: scale(1) !important;
		opacity: 1 !important;
		pointer-events: auto !important;
		width: var(--fab-button-size) !important;
		height: var(--fab-button-size) !important;
		margin: 0 !important;
		border-width: 1px !important;
		border-style: solid !important;
		border-color: rgba(255, 255, 255, 0.15) !important;
		padding: 0.25rem !important;
		overflow: hidden !important;
		box-sizing: border-box !important;
	}

	:global(
		html:not(.dark).fab-visibility-locked #scroll-toggle-btn.fab-lock-visible
	) {
		border-color: var(--line-color) !important;
	}

	:global(html.fab-visibility-locked #scroll-toggle-btn.fab-lock-visible.hide) {
		transform: scale(1) !important;
		opacity: 1 !important;
		pointer-events: auto !important;
		width: var(--fab-button-size) !important;
		height: var(--fab-button-size) !important;
		min-width: var(--fab-button-size) !important;
		min-height: var(--fab-button-size) !important;
		margin: 0 !important;
		padding: 0.25rem !important;
		border-width: 1px !important;
		border-style: solid !important;
	}

	:global(html.fab-visibility-locked #scroll-toggle-btn.fab-lock-visible svg) {
		opacity: 1 !important;
	}

	:global(
		html.fab-visibility-locked .floating-control-item.fab-lock-collapsed
	) {
		max-height: 0 !important;
		opacity: 0 !important;
		transform: translateY(0.25rem) scale(0.92) !important;
		margin-top: 0 !important;
		pointer-events: none !important;
		overflow: hidden !important;
	}

	@media (max-width: 1024px) {
		:global(:root) {
			--fab-group-right: 1rem;
			--fab-group-bottom: 6rem;
			--fab-group-base-bottom: 6rem;
		}

		.floating-controls-container {
			right: var(--fab-group-right);
			bottom: var(--fab-group-bottom);
		}
	}

	@media (max-width: 768px) {
		:global(:root) {
			--fab-group-right: 0.75rem;
			--fab-group-bottom: 5rem;
			--fab-group-base-bottom: 5rem;
			--fab-button-size: 2.75rem;
		}

		.floating-controls-container {
			right: var(--fab-group-right);
			bottom: var(--fab-group-bottom);
		}
	}

	@media (max-width: 480px) {
		:global(:root) {
			--fab-group-right: 0.5rem;
			--fab-group-bottom: 4.5rem;
			--fab-group-base-bottom: 4.5rem;
			--fab-button-size: 2.5rem;
		}

		.floating-controls-container {
			right: var(--fab-group-right);
			bottom: var(--fab-group-bottom);
		}
	}

	@media (max-width: 320px) {
		:global(:root) {
			--fab-group-right: 0.25rem;
			--fab-group-bottom: 4rem;
			--fab-group-base-bottom: 4rem;
		}

		.floating-controls-container {
			right: var(--fab-group-right);
			bottom: var(--fab-group-bottom);
		}
	}

	@media (orientation: landscape) and (max-height: 500px) {
		:global(:root) {
			--fab-group-bottom: 4rem;
			--fab-group-base-bottom: 4rem;
		}

		.floating-controls-container {
			bottom: var(--fab-group-bottom);
		}
	}
</style>

<script is:inline>
	(() => {
		if (typeof window.FloatingControlsManager === "undefined") {
			window.FloatingControlsManager = class FloatingControlsManager {
				constructor() {
					this.isMusicPanelExpanded = false;
					this.visibilityUpdateScheduled = false;
					this.mermaidRendering = false;
					this.mermaidRenderTimer = null;
					this.handleMusicPanelState =
						this.handleMusicPanelState.bind(this);
					this.handleMermaidRenderStart =
						this.handleMermaidRenderStart.bind(this);
					this.handleMermaidRenderDone =
						this.handleMermaidRenderDone.bind(this);
					this.scheduleVisibilityUpdate =
						this.scheduleVisibilityUpdate.bind(this);
					this.initFloatingControlVisibility =
						this.initFloatingControlVisibility.bind(this);
					this.init();
				}

				init() {
					document.addEventListener(
						"DOMContentLoaded",
						this.initFloatingControlVisibility,
					);
					document.addEventListener(
						"astro:page-load",
						this.initFloatingControlVisibility,
					);
					window.addEventListener(
						"floating-control:visibility",
						this.scheduleVisibilityUpdate,
					);
					window.addEventListener(
						"music-sidebar:state",
						this.handleMusicPanelState,
					);
					window.addEventListener(
						"mermaid:render:start",
						this.handleMermaidRenderStart,
					);
					window.addEventListener(
						"mermaid:render:done",
						this.handleMermaidRenderDone,
					);
					this.initFloatingControlVisibility();
				}

				updateFloatingControlVisibility() {
					if (this.isMusicPanelExpanded) {
						return;
					}

					const items = document.querySelectorAll(
						".floating-control-item[data-control-key]",
					);
					const totalItems = items.length;
					let hasVisibleItem = false;
					let visibleCount = 0;

					for (const item of items) {
						const key = item.getAttribute("data-control-key");
						const visible =
							key !== "scroll-toggle" ||
							!document
								.getElementById("scroll-toggle-btn")
								?.classList.contains("hide");

						item.classList.toggle("is-collapsed", !visible);
						item.classList.toggle(
							"is-stacked",
							visible && hasVisibleItem,
						);

						if (visible) {
							hasVisibleItem = true;
							visibleCount += 1;
						}
					}

					document.documentElement.style.setProperty(
						"--fab-visible-count",
						String(Math.max(visibleCount, 1)),
					);

					if (visibleCount >= totalItems) {
						document.documentElement.style.removeProperty(
							"--fab-group-bottom",
						);
						return;
					}

					const baseBottom = parseFloat(
						getComputedStyle(document.documentElement).getPropertyValue(
							"--fab-group-base-bottom",
						),
					);
					if (!isNaN(baseBottom) && totalItems > 0) {
						const minBottom = 1.5;
						const ratio = visibleCount / totalItems;
						const newBottom =
							minBottom + (baseBottom - minBottom) * ratio;
						document.documentElement.style.setProperty(
							"--fab-group-bottom",
							newBottom + "rem",
						);
					}
				}

				initFloatingControlVisibility() {
					this.updateFloatingControlVisibility();
				}

				lockFloatingControlVisibility() {
					document.documentElement.classList.add(
						"fab-visibility-locked",
					);

					const items = document.querySelectorAll(
						".floating-control-item[data-control-key]",
					);
					for (const item of items) {
						const key = item.getAttribute("data-control-key");
						const id =
							key === "scroll-toggle"
								? "scroll-toggle-btn"
								: null;

						if (!id) {
							continue;
						}

						const button = document.getElementById(id);
						const isVisible = Boolean(
							button && !button.classList.contains("hide"),
						);
						item.classList.toggle("fab-lock-collapsed", !isVisible);
					}

					const button = document.getElementById("scroll-toggle-btn");
					const isVisible = Boolean(
						button && !button.classList.contains("hide"),
					);
					button?.classList.toggle("fab-lock-visible", isVisible);
				}

				unlockFloatingControlVisibility() {
					document.documentElement.classList.remove(
						"fab-visibility-locked",
					);

					const items = document.querySelectorAll(
						".floating-control-item[data-control-key]",
					);
					for (const item of items) {
						item.classList.remove("fab-lock-collapsed");
					}

					document
						.getElementById("scroll-toggle-btn")
						?.classList.remove("fab-lock-visible");
				}

				handleMusicPanelState(event) {
					const expanded = Boolean(event?.detail?.isExpanded);
					if (expanded === this.isMusicPanelExpanded) {
						return;
					}

					this.isMusicPanelExpanded = expanded;
					if (this.isMusicPanelExpanded) {
						this.lockFloatingControlVisibility();
					} else {
						this.unlockFloatingControlVisibility();
						this.updateFloatingControlVisibility();
					}
				}

				handleMermaidRenderStart() {
					this.mermaidRendering = true;
				}

				handleMermaidRenderDone() {
					clearTimeout(this.mermaidRenderTimer);
					this.mermaidRenderTimer = setTimeout(() => {
						this.mermaidRendering = false;
						this.updateFloatingControlVisibility();
					}, 120);
				}

				scheduleVisibilityUpdate() {
					if (
						this.visibilityUpdateScheduled ||
						this.mermaidRendering
					) {
						return;
					}
					this.visibilityUpdateScheduled = true;
					requestAnimationFrame(() => {
						this.visibilityUpdateScheduled = false;
						if (!this.mermaidRendering) {
							this.updateFloatingControlVisibility();
						}
					});
				}

				destroy() {
					document.removeEventListener(
						"DOMContentLoaded",
						this.initFloatingControlVisibility,
					);
					document.removeEventListener(
						"astro:page-load",
						this.initFloatingControlVisibility,
					);
					window.removeEventListener(
						"floating-control:visibility",
						this.scheduleVisibilityUpdate,
					);
					window.removeEventListener(
						"music-sidebar:state",
						this.handleMusicPanelState,
					);
					window.removeEventListener(
						"mermaid:render:start",
						this.handleMermaidRenderStart,
					);
					window.removeEventListener(
						"mermaid:render:done",
						this.handleMermaidRenderDone,
					);
					clearTimeout(this.mermaidRenderTimer);
				}
			};
		}

		window.__floatingControlsManager?.destroy?.();
		window.__floatingControlsManager =
			new window.FloatingControlsManager();
	})();
</script>
