---
import AnimeCard from "./AnimeCard.astro";

interface StatusInfo {
	text: string;
	class: string;
	icon: string;
}

interface AnimeItem {
	type?: string;
	title: string;
	cover: string;
	link: string;
	status: string;
	rating: number;
	progress: number;
	totalEpisodes: number;
	description: string;
	year: string;
	studio: string;
	genre: string[];
}

interface Props {
	visibleAnimeList: AnimeItem[];
	hiddenAnimeList: AnimeItem[];
	statusMap: Record<string, StatusInfo>;
	yearLabel: string;
	studioLabel: string;
	activeAnimeType?: string;
}

const {
	visibleAnimeList,
	hiddenAnimeList,
	statusMap,
	yearLabel,
	studioLabel,
	activeAnimeType = "anime",
} = Astro.props;

const animeList = [...visibleAnimeList, ...hiddenAnimeList];
---

<div
	id="anime-list-container"
	class="anime-grid-container grid gap-4 md:gap-6 opacity-0 transition-opacity duration-300"
	data-active-anime-type={activeAnimeType}
>
	{
		animeList.map((anime) => {
			const statusInfo = statusMap[anime.status] || {
				text: anime.status,
				class: "btn-regular",
				icon: "?",
			};
			return (
				<AnimeCard
					anime={anime}
					statusInfo={statusInfo}
					yearLabel={yearLabel}
					studioLabel={studioLabel}
				/>
			);
		})
	}
</div>
