---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import { url } from "../../../utils/url-utils";
---

<div class="card-base p-3">
	<a
		aria-label="Go to About Page"
		href={url("/about/")}
		class="group relative mx-auto mt-1 mb-3 block max-w-[12rem] overflow-hidden rounded-xl active:scale-95 lg:mx-0 lg:mt-0 lg:max-w-none"
	>
		<div class="absolute z-50 flex h-full w-full items-center justify-center transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50">
			<Icon
				name="fa7-regular:address-card"
				class="text-5xl text-white transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100"
			/>
		</div>
		<img
			src={profileConfig.avatar || ""}
			alt="作者头像"
			class="mx-auto h-full w-full object-cover lg:mt-0"
			loading="eager"
			fetchpriority="high"
		/>
	</a>

	<div class="px-2">
		<div class="mb-1 text-center text-xl font-bold transition dark:text-neutral-50">
			{profileConfig.name}
		</div>
		<div class="mx-auto mb-2 h-1 w-5 rounded-full bg-[var(--primary)] transition"></div>

		<div class="mb-2.5 text-center text-sm leading-[1.7] text-neutral-400 transition lg:text-[0.95rem]">
			{
				profileConfig.typewriter?.enable ? (
					<span
						class="profile-bio-animated inline-block max-w-full"
						data-text={profileConfig.bio || ""}
						data-speed={profileConfig.typewriter.speed || 125}
						data-pause-time={profileConfig.typewriter.pauseTime || 10000}
						data-pause-at-text={profileConfig.typewriter.pauseAtText || ""}
						data-pause-at-text-duration={profileConfig.typewriter.pauseAtTextDuration || 0}
						data-loop={profileConfig.typewriter.loop ? "true" : "false"}
					></span>
				) : (
					profileConfig.bio
				)
			}
		</div>

		<div class="mb-1 flex flex-wrap justify-center gap-2">
			{
				profileConfig.links.length > 1 &&
					profileConfig.links.map((item) => (
						<a
							rel="me"
							aria-label={item.name}
							href={item.url}
							target="_blank"
							class="btn-regular h-10 w-10 rounded-lg active:scale-90"
						>
							<Icon name={item.icon} class="text-[1.5rem]" />
						</a>
					))
			}
			{
				profileConfig.links.length === 1 && (
					<a
						rel="me"
						aria-label={profileConfig.links[0].name}
						href={profileConfig.links[0].url}
						target="_blank"
						class="btn-regular h-10 gap-2 rounded-lg px-3 font-bold active:scale-95"
					>
						<Icon
							name={profileConfig.links[0].icon}
							class="text-[1.5rem]"
						/>
						{profileConfig.links[0].name}
					</a>
				)
			}
		</div>

		<div class="umami-stats-container hidden">
			<hr class="my-2 border-t border-dashed border-black/10 transition-colors duration-150 dark:border-white/10" />
			<div class="mt-2 text-center text-sm text-50 transition-colors duration-150">
				<Icon
					name="fa7-solid:eye"
					class="mr-1 inline-block text-sm text-50 align-middle"
				/>
				<span class="site-stats-display">{i18n(I18nKey.profileStatsLoading)}</span>
			</div>
		</div>
	</div>
</div>

<script
	is:inline
	define:vars={{
		profileStatsPageViews: i18n(I18nKey.profileStatsPageViews),
		profileStatsVisits: i18n(I18nKey.profileStatsVisits),
	}}
>
	function generateStatsText(pageViews, visits) {
		return `${profileStatsPageViews} ${pageViews} 路 ${profileStatsVisits} ${visits}`;
	}

	async function fetchSiteStats(isRetry = false) {
		const containers = document.querySelectorAll(".umami-stats-container");

		if (!window.oddmisc) {
			if (!isRetry) {
				setTimeout(() => fetchSiteStats(true), 500);
			} else {
				containers.forEach((c) => c.classList.add("hidden"));
			}
			return;
		}

		try {
			const stats = await window.oddmisc.getSiteStats();
			const pageViews = stats.pageviews || 0;
			const visits = stats.visits || 0;

			if (pageViews === 0 && visits === 0) {
				containers.forEach((c) => c.classList.add("hidden"));
				return;
			}

			containers.forEach((c) => c.classList.remove("hidden"));
			document.querySelectorAll(".site-stats-display").forEach((el) => {
				el.textContent = generateStatsText(pageViews, visits);
			});
		} catch (error) {
			console.error("Error fetching site stats:", error);
			containers.forEach((c) => c.classList.add("hidden"));
		}
	}

	class ProfileBioAnimator {
		constructor(element) {
			this.element = element;
			this.text = element.dataset.text || "";
			this.speed = parseInt(element.dataset.speed || "125");
			this.pauseTime = parseInt(element.dataset.pauseTime || "10000");
			this.pauseAtText = element.dataset.pauseAtText || "";
			this.pauseAtTextDuration = parseInt(
				element.dataset.pauseAtTextDuration || "0",
			);
			this.loop = element.dataset.loop === "true";
			this.index = 0;
			this.timeoutId = null;
			this.pauseTriggered = false;
			this.start();
		}

		schedule(next, delay) {
			this.timeoutId = window.setTimeout(next, delay);
		}

		type = () => {
			if (this.index < this.text.length) {
				this.index++;
				this.element.textContent = this.text.slice(0, this.index);

				if (
					this.pauseAtText &&
					!this.pauseTriggered &&
					this.element.textContent === this.pauseAtText
				) {
					this.pauseTriggered = true;
					this.schedule(this.type, this.pauseAtTextDuration);
					return;
				}

				this.schedule(this.type, this.speed);
				return;
			}

			if (!this.loop) return;
			this.schedule(this.exit, this.pauseTime);
		};

		exit = () => {
			this.element.classList.add("profile-bio-exit");
			this.schedule(() => {
				this.element.classList.remove("profile-bio-exit");
				this.element.textContent = "";
				this.index = 0;
				this.pauseTriggered = false;
				this.schedule(this.type, 240);
			}, 480);
		};

		start() {
			if (!this.text) return;
			this.element.textContent = "";
			this.schedule(this.type, this.speed);
		}
	}

	const initProfileBioAnimator = () => {
		document.querySelectorAll(".profile-bio-animated").forEach((element) => {
			if (element.dataset.animated === "true") return;
			element.dataset.animated = "true";
			new ProfileBioAnimator(element);
		});
	};

	if (!window.__siteStatsFetching) {
		window.__siteStatsFetching = true;
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", () => fetchSiteStats());
		} else {
			fetchSiteStats();
		}
	}

	document.addEventListener("DOMContentLoaded", initProfileBioAnimator);
	document.addEventListener("swup:contentReplaced", initProfileBioAnimator);
</script>

<style>
	.profile-bio-animated {
		max-width: 100%;
		white-space: nowrap;
		transform: translateY(0);
		opacity: 1;
		transition:
			transform 0.48s ease,
			opacity 0.48s ease;
	}

	.profile-bio-animated.profile-bio-exit {
		transform: translateY(0.8rem);
		opacity: 0;
	}
</style>
